{
  "auth": {
    "igptAuth": {
      "customAuth": false,
      "dependsOn": [],
      "frontendAuthConfig": {
        "mfaConfiguration": "OPTIONAL",
        "mfaTypes": [
          "SMS"
        ],
        "passwordProtectionSettings": {
          "passwordPolicyCharacters": [
            "REQUIRES_LOWERCASE",
            "REQUIRES_UPPERCASE",
            "REQUIRES_NUMBERS",
            "REQUIRES_SYMBOLS"
          ],
          "passwordPolicyMinLength": 8
        },
        "signupAttributes": [
          "EMAIL"
        ],
        "socialProviders": [],
        "usernameAttributes": [
          "EMAIL",
          "PHONE_NUMBER"
        ],
        "verificationMechanisms": [
          "EMAIL"
        ]
      },
      "providerPlugin": "awscloudformation",
      "service": "Cognito"
    }
  },
  "function": {
    "IGPTauthCreateAuthChallenge": {
      "build": true,
      "providerPlugin": "awscloudformation",
      "service": "Lambda"
    },
    "IGPTauthDefineAuthChallenge": {
      "build": true,
      "providerPlugin": "awscloudformation",
      "service": "Lambda"
    }
  },
  "parameters": {
    "AMPLIFY_function_IGPTauthCreateAuthChallenge_deploymentBucketName": {
      "usedBy": [
        {
          "category": "function",
          "resourceName": "IGPTauthCreateAuthChallenge"
        }
      ]
    },
    "AMPLIFY_function_IGPTauthCreateAuthChallenge_s3Key": {
      "usedBy": [
        {
          "category": "function",
          "resourceName": "IGPTauthCreateAuthChallenge"
        }
      ]
    },
    "AMPLIFY_function_IGPTauthDefineAuthChallenge_deploymentBucketName": {
      "usedBy": [
        {
          "category": "function",
          "resourceName": "IGPTauthDefineAuthChallenge"
        }
      ]
    },
    "AMPLIFY_function_IGPTauthDefineAuthChallenge_s3Key": {
      "usedBy": [
        {
          "category": "function",
          "resourceName": "IGPTauthDefineAuthChallenge"
        }
      ]
    }
  }
}